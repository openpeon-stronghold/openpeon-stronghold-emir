{
  "cesp_version": "1.0",
  "name": "stronghold-emir",
  "display_name": "The Emir (Stronghold Crusader)",
  "version": "1.0.0",
  "author": { "name": "Marko Jevic", "github": "koyev" },
  "license": "fair-use",
  "language": "en",
  "categories": {
    "session.start": {
      "sounds": [
        { "file": "sounds/em_add_player_01.wav", "label": "Greetings" }
      ]
    },
    "task.acknowledge": {
      "sounds": [
        { "file": "sounds/em_willattack_01.wav", "label": "You are right" },
        { "file": "sounds/em_sent_01.wav", "label": "You shall have your supplies" },
        { "file": "sounds/em_siege_01.wav", "label": "Order to siege" }
      ]
    },
    "task.complete": {
      "sounds": [
        { "file": "sounds/em_vict_02.wav", "label": "Oh, this is easy" },
        { "file": "sounds/em_vict_04.wav", "label": "Winning too easily" },
        { "file": "sounds/em_boast_01.wav", "label": "How about that" }
      ]
    },
    "task.error": {
      "sounds": [
        { "file": "sounds/em_anger_01.wav", "label": "By thunder, what a disaster" },
        { "file": "sounds/em_anger_02.wav", "label": "I may be forced to act" }
      ]
    },
    "input.required": {
      "sounds": [
        { "file": "sounds/em_help_01.wav", "label": "Beset on all sides" },
        { "file": "sounds/em_req_01.wav", "label": "Stores most depleted" }
      ]
    },
    "resource.limit": {
      "sounds": [
        { "file": "sounds/em_notsent_01.wav", "label": "Difficult to send goods" },
        { "file": "sounds/em_nohelp_01.wav", "label": "Cannot come to your aid" }
      ]
    },
    "user.spam": {
      "sounds": [
        { "file": "sounds/em_noattack_01.wav", "label": "Too risky, far too risky" },
        { "file": "sounds/em_noattack_02.wav", "label": "Must decline" }
      ]
    }
  }
}
